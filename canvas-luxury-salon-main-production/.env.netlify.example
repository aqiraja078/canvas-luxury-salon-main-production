# =============================================================================
# Netlify environment variables — copy into Netlify dashboard
# Site settings → Environment variables → Add a variable
# Scope: Production (required). Add Deploy previews if you test /admin there.
#
# Do NOT commit real secrets. Generate new values:
#   openssl rand -hex 24
# =============================================================================

# --- Required (build + runtime) ---
NEXT_PUBLIC_SITE_URL=https://humasalon.com.pk

# --- Required (admin login security) ---
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-24
ADMIN_2FA_SECRET=replace-with-another-openssl-rand-hex-24

# --- Strongly recommended (emergency owner login) ---
ADMIN_USERNAME=huma.owner
ADMIN_PASSWORD=replace-with-strong-password-or-openssl-rand-hex-24

# --- Optional (booking confirmation / cancellation emails via Resend) ---
# RESEND_API_KEY=re_xxxx
# NOTIFY_EMAIL_FROM=Huma Beauty Saloon <bookings@yourdomain.com>

# --- Local dev only (do NOT add on Netlify) ---
# ADMIN_COOKIE_INSECURE=true

# =============================================================================
# Netlify Blobs (CMS: services, offers, team, home page, users)
# No extra env vars needed — enabled automatically when deployed on Netlify.
# First deploy seeds from ./data/*.json; edits in /admin persist in Blobs.
# =============================================================================

# Public site URL for metadata / OG / sitemap (https://..., no trailing slash).
# Override with your real domain; code fallback is humasalon.com.pk if unset.
NEXT_PUBLIC_SITE_URL=https://humasalon.com.pk

# Admin user defaults for local dev.
# In production set ADMIN_SESSION_SECRET (long random string; no spaces around =).
# Admin logins are stored in ./data/users.json (not committed).
# On first run, unique passwords are written to ./data/admin-credentials.txt
ADMIN_SESSION_SECRET=random-long-secret-string
# Optional emergency owner login (if set, works alongside CMS users):
# ADMIN_USERNAME=huma.owner
# ADMIN_PASSWORD="your-strong-password"
# If login succeeds but /admin redirects back to login on http://localhost, set:
# ADMIN_COOKIE_INSECURE=true

# CMS data (services, offers, team, users) is stored under ./data/ and Netlify Blobs in production.
# Default admin accounts (unique passwords on first seed — see data/admin-credentials.txt):
#   huma.owner      — full owner access
#   huma.reception  — bookings, services, offers, courses (view)
#   huma.contact    — bookings & course applications (view)

# --- Guest email (when admin sets booking to Confirmed or Cancelled) ---
# Resend: https://resend.com — verify a sending domain, then:
# RESEND_API_KEY=re_xxxx
# NOTIFY_EMAIL_FROM="Huma beauty saloon <bookings@yourdomain.com>"
# If missing, status updates still work — email is skipped.

# Production checklist:
# - Set ADMIN_PASSWORD and ADMIN_SESSION_SECRET (long random strings; never commit .env.local).
# - Set NEXT_PUBLIC_SITE_URL to your live origin (https://...) for OG, sitemap, and JSON-LD.
# - Prefer HTTPS so the admin session cookie can use the Secure flag.
# - Configure Resend (RESEND_API_KEY + NOTIFY_EMAIL_FROM) for guest emails on confirm & cancel.

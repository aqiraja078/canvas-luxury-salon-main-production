# =============================================================================
# Environment variables — Huma Beauty Saloon (Next.js)
# Copy to .env.local for local development / production testing.
# For Netlify: see .env.netlify.example and paste into Netlify dashboard.
# =============================================================================

# Public site URL (https://..., no trailing slash)
NEXT_PUBLIC_SITE_URL=https://humasalon.com.pk

# Admin session signing (required in production — long random string)
ADMIN_SESSION_SECRET=random-long-secret-string

# 2FA cookie signing (required in production)
ADMIN_2FA_SECRET=another-random-long-secret-string

# Optional emergency owner login (alongside CMS users in data/users.json)
# ADMIN_USERNAME=huma.owner
# ADMIN_PASSWORD=your-strong-password

# Local HTTP only — if /admin login loops on http://localhost:
# ADMIN_COOKIE_INSECURE=true

# Guest emails on booking Confirmed / Cancelled (optional)
# RESEND_API_KEY=re_xxxx
# NOTIFY_EMAIL_FROM=Huma Beauty Saloon <bookings@yourdomain.com>

# CMS data: ./data/ locally, Netlify Blobs in production (no extra env vars).
